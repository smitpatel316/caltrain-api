# Caltrain API Configuration
# Copy this file to .env and fill in your values

# 511.org API Key (required for real-time data)
# Get your key at: https://511.org/open-data/token
FIVE_ELEVEN_API_KEY=your_actual_token_here

# GTFS static data refresh interval (hours)
GTFS_REFRESH_HOURS=24

# Cache TTL in minutes
CACHE_TTL_MINUTES=5

# Debug mode (set to false in production)
DEBUG=false

# Rate limiting - requests per hour to 511.org API
RATE_LIMIT_REQUESTS_PER_HOUR=60

# Maximum retries after rate limiting
RATE_LIMIT_MAX_RETRIES=3

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Data directory (should be writable)
DATA_DIR=data
